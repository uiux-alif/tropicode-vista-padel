// Vista Padel Club — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Court {
  id        String        @id @default(cuid())
  name      String
  type      String
  surface   String
  lighting  String
  capacity  Int           @default(4)
  badge     String?
  features  String[]
  photoUrl  String?
  isActive  Boolean       @default(true)
  sortOrder Int           @default(0)
  bookings  Booking[]
  blocks    SlotBlock[]
  pricing   CourtPricing?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model CourtPricing {
  id          String @id @default(cuid())
  courtId     String @unique
  court       Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  priceNormal Int
  pricePeak   Int
}

model GlobalPricing {
  id            String @id @default(cuid())
  peakHourStart Int    @default(17)
  peakHourEnd   Int    @default(22)
  racketRental  Int    @default(30000)
  ballRental    Int    @default(15000)
  coachingAddon Int    @default(200000)
}

model Booking {
  id             String        @id @default(cuid())
  refNumber      String        @unique
  courtId        String
  court          Court         @relation(fields: [courtId], references: [id])
  date           DateTime
  startTime      String
  duration       Int
  endTime        String
  bookerName     String
  bookerWa       String
  players        Int
  addonRacket    Boolean       @default(false)
  addonBall      Boolean       @default(false)
  addonCoaching  Boolean       @default(false)
  notes          String?
  adminNotes     String?
  estimatedTotal Int
  memberRef      String?  // MBR-YYYY-NNNN if member applied discount
  memberDiscount Int      @default(0) // % discount applied
  status         BookingStatus @default(PENDING)
  lockedUntil    DateTime
  confirmedAt    DateTime?
  rejectedAt     DateTime?
  cancelledAt    DateTime?
  expiredAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([date, courtId])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
}

model SlotBlock {
  id        String   @id @default(cuid())
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())

  @@index([date, courtId])
}

model Coach {
  id             String         @id @default(cuid())
  name           String
  title          String
  specialty      String
  experience     String
  certifications String[]
  bio            String?
  photoUrl       String?
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  programs       CoachProgram[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model CoachProgram {
  id       String @id @default(cuid())
  coachId  String
  coach    Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name     String
  duration String
  price    Int
  level    String
}

model Facility {
  id          String  @id @default(cuid())
  name        String
  description String
  icon        String
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
}

model MembershipPlan {
  id              String   @id @default(cuid())
  name            String
  price           Int
  billingPeriod   String
  description     String?
  features        String[]
  discountPercent Int      @default(0) // % off court fees for members
  isFeatured      Boolean  @default(false)
  ctaLabel        String   @default("Get Started")
  ctaWaMessage    String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  members         Member[]
}

model Member {
  id            String         @id @default(cuid())
  refNumber     String         @unique
  name          String
  waNumber      String
  email         String?
  planId        String
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  status        MemberStatus   @default(ACTIVE)
  startDate     DateTime
  expiresAt     DateTime
  billingPeriod String
  paidAmount    Int
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@index([waNumber])
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PAUSED
  CANCELLED
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  role      String
  rating    Int     @default(5)
  text      String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  waNumber   String?
  subject    String
  message    String
  isRead     Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  supabaseId   String?  @unique
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
}
