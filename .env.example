# ── Database (Supabase Postgres) ──
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── Admin auth ──
ADMIN_EMAIL="admin@vistapadel.id"
ADMIN_PASSWORD="vista-admin-2026"
AUTH_SECRET="change-this-to-a-long-random-secret-min-32-chars"

# ── Cron protection ──
CRON_SECRET="change-this-cron-secret"

# ── Site ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Analytics ──
# Vercel Analytics + Speed Insights are zero-config on Vercel (no key needed here).
# PostHog — get your key at posthog.com (free tier available)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
